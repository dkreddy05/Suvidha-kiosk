<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context" name="APP_NAME"
                    source="spring.application.name"
                    defaultValue="suvidha"/>
    <springProperty scope="context" name="ENV"
                    source="suvidha.env"
                    defaultValue="dev"/>
    <springProperty scope="context" name="INSTANCE_ID"
                    source="spring.cloud.client.hostname"
                    defaultValue="unknown"/>
    <springProperty scope="context" name="LOG_LEVEL"
                    source="logging.level.root"
                    defaultValue="INFO"/>
    <springProperty scope="context" name="LOG_FILE_MAX_SIZE"
                    source="suvidha.logging.file.max-size"
                    defaultValue="100MB"/>
    <springProperty scope="context" name="LOG_FILE_MAX_HISTORY"
                    source="suvidha.logging.file.max-history"
                    defaultValue="30"/>
    <springProperty scope="context" name="LOG_FILE_TOTAL_SIZE_CAP"
                    source="suvidha.logging.file.total-size-cap"
                    defaultValue="10GB"/>
    <springProperty scope="context" name="LOG_PATH"
                    source="logging.file.path"
                    defaultValue="logs"/>


    <conversionRule conversionWord="mask"
                    converterClass="com.suvidha.common.logging.SensitiveDataMaskingConverter"/>

    <!-- ── JSON Console Appender (production) ─────────────────────── -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <timestamp>
                    <fieldName>timestamp</fieldName>
                    <pattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</pattern>
                    <timeZone>UTC</timeZone>
                </timestamp>
                <logLevel>
                    <fieldName>level</fieldName>
                </logLevel>
                <loggerName>
                    <fieldName>logger</fieldName>
                    <shortenedLoggerNameLength>36</shortenedLoggerNameLength>
                </loggerName>
                <threadName>
                    <fieldName>thread</fieldName>
                </threadName>
                <pattern>
                    <pattern>
                        {"message":"%mask%msg"}
                    </pattern>
                </pattern>
                <mdc>
                    <includeMdcKeyName>traceId</includeMdcKeyName>
                    <includeMdcKeyName>spanId</includeMdcKeyName>
                    <includeMdcKeyName>correlationId</includeMdcKeyName>
                    <includeMdcKeyName>sessionId</includeMdcKeyName>
                    <includeMdcKeyName>userId</includeMdcKeyName>
                    <includeMdcKeyName>httpMethod</includeMdcKeyName>
                    <includeMdcKeyName>httpUrl</includeMdcKeyName>
                    <includeMdcKeyName>httpDurationMs</includeMdcKeyName>
                    <includeMdcKeyName>httpStatus</includeMdcKeyName>
                    <includeMdcKeyName>httpRemoteIp</includeMdcKeyName>
                </mdc>
                <stackTrace>
                    <fieldName>error.stack_trace</fieldName>
                    <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                        <maxDepthPerThrowable>30</maxDepthPerThrowable>
                        <maxLength>2048</maxLength>
                        <shortenedClassNameLength>36</shortenedClassNameLength>
                        <exclude>sun\.reflect\..*\.invoke.*</exclude>
                        <exclude>net\.sf\.cglib\.proxy\.MethodProxy\.invoke</exclude>
                        <exclude>org\.springframework\.aop\..*</exclude>
                        <rootCauseFirst>true</rootCauseFirst>
                    </throwableConverter>
                </stackTrace>
                <pattern>
                    <pattern>
                        {
                            "service": "${APP_NAME}",
                            "env": "${ENV}",
                            "instance_id": "${INSTANCE_ID}"
                        }
                    </pattern>
                </pattern>
            </providers>
        </encoder>
    </appender>

    <!-- ── JSON File Appender with rolling policy ─────────────────── -->
    <springProfile name="!test">
        <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/${APP_NAME}.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/${APP_NAME}-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>${LOG_FILE_MAX_SIZE}</maxFileSize>
                <maxHistory>${LOG_FILE_MAX_HISTORY}</maxHistory>
                <totalSizeCap>${LOG_FILE_TOTAL_SIZE_CAP}</totalSizeCap>
                <cleanHistoryOnStart>true</cleanHistoryOnStart>
            </rollingPolicy>
            <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                <providers>
                    <timestamp>
                        <fieldName>timestamp</fieldName>
                        <pattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</pattern>
                        <timeZone>UTC</timeZone>
                    </timestamp>
                    <logLevel>
                        <fieldName>level</fieldName>
                    </logLevel>
                    <loggerName>
                        <fieldName>logger</fieldName>
                        <shortenedLoggerNameLength>36</shortenedLoggerNameLength>
                    </loggerName>
                    <threadName>
                        <fieldName>thread</fieldName>
                    </threadName>
                    <pattern>
                        <pattern>
                            {"message":"%mask%msg"}
                        </pattern>
                    </pattern>
                    <mdc>
                        <includeMdcKeyName>traceId</includeMdcKeyName>
                        <includeMdcKeyName>spanId</includeMdcKeyName>
                        <includeMdcKeyName>correlationId</includeMdcKeyName>
                        <includeMdcKeyName>sessionId</includeMdcKeyName>
                        <includeMdcKeyName>userId</includeMdcKeyName>
                        <includeMdcKeyName>httpMethod</includeMdcKeyName>
                        <includeMdcKeyName>httpUrl</includeMdcKeyName>
                        <includeMdcKeyName>httpDurationMs</includeMdcKeyName>
                        <includeMdcKeyName>httpStatus</includeMdcKeyName>
                        <includeMdcKeyName>httpRemoteIp</includeMdcKeyName>
                    </mdc>
                    <stackTrace>
                        <fieldName>error.stack_trace</fieldName>
                        <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
                            <maxDepthPerThrowable>30</maxDepthPerThrowable>
                            <maxLength>2048</maxLength>
                            <shortenedClassNameLength>36</shortenedClassNameLength>
                            <exclude>sun\.reflect\..*\.invoke.*</exclude>
                            <exclude>net\.sf\.cglib\.proxy\.MethodProxy\.invoke</exclude>
                            <exclude>org\.springframework\.aop\..*</exclude>
                            <rootCauseFirst>true</rootCauseFirst>
                        </throwableConverter>
                    </stackTrace>
                    <pattern>
                        <pattern>
                            {
                                "service": "${APP_NAME}",
                                "env": "${ENV}",
                                "instance_id": "${INSTANCE_ID}"
                            }
                        </pattern>
                    </pattern>
                </providers>
            </encoder>
        </appender>
    </springProfile>

    <!-- ── Async wrapper (non-blocking I/O) ───────────────────────── -->
    <appender name="ASYNC_JSON_CONSOLE" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>8192</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <neverBlock>true</neverBlock>
        <includeCallerData>false</includeCallerData>
        <appender-ref ref="JSON_CONSOLE"/>
    </appender>

    <springProfile name="!test">
        <appender name="ASYNC_JSON_FILE" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>8192</queueSize>
            <discardingThreshold>0</discardingThreshold>
            <neverBlock>true</neverBlock>
            <includeCallerData>false</includeCallerData>
            <appender-ref ref="JSON_FILE"/>
        </appender>
    </springProfile>

    <!-- ── Plain text console (development) ───────────────────────── -->
    <appender name="PLAIN_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] [%X{traceId:-}] [%X{correlationId:-}] [%X{sessionId:-}] %-5level %logger{36} - %mask%msg%n</pattern>
        </encoder>
    </appender>

    <!-- ── Profile: production / docker ───────────────────────────── -->
    <springProfile name="prod,docker">
        <root level="${LOG_LEVEL}">
            <appender-ref ref="ASYNC_JSON_CONSOLE"/>
            <appender-ref ref="ASYNC_JSON_FILE"/>
        </root>
    </springProfile>

    <!-- ── Profile: staging ───────────────────────────────────────── -->
    <springProfile name="staging">
        <root level="${LOG_LEVEL}">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
    </springProfile>

    <!-- ── Profile: test ─────────────────────────────────────────── -->
    <springProfile name="test">
        <root level="${LOG_LEVEL}">
            <appender-ref ref="PLAIN_CONSOLE"/>
        </root>
    </springProfile>

    <!-- ── Profile: dev / default ─────────────────────────────────── -->
    <springProfile name="!prod,!docker,!staging,!test">
        <root level="${LOG_LEVEL}">
            <appender-ref ref="PLAIN_CONSOLE"/>
        </root>
    </springProfile>

    <!-- ── Framework noise reduction ──────────────────────────────── -->
    <logger name="org.springframework" level="WARN"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.springframework.security" level="INFO"/>
    <logger name="org.hibernate" level="WARN"/>
    <logger name="org.hibernate.SQL" level="DEBUG"/>
    <logger name="io.netty" level="WARN"/>
    <logger name="com.zaxxer.hikari" level="INFO"/>
    <logger name="org.flywaydb" level="INFO"/>

    <!-- ── Application packages ───────────────────────────────────── -->
    <logger name="com.suvidha" level="${LOG_LEVEL}"/>

    <!-- ── Audit trail logger (separate file) ─────────────────────── -->
    <springProfile name="!test">
        <appender name="AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>${LOG_PATH}/${APP_NAME}-audit.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>${LOG_PATH}/${APP_NAME}-audit-%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
                <maxFileSize>50MB</maxFileSize>
                <maxHistory>90</maxHistory>
                <totalSizeCap>5GB</totalSizeCap>
            </rollingPolicy>
            <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                <providers>
                    <timestamp>
                        <fieldName>timestamp</fieldName>
                        <pattern>yyyy-MM-dd'T'HH:mm:ss.SSS'Z'</pattern>
                        <timeZone>UTC</timeZone>
                    </timestamp>
                    <logLevel>
                        <fieldName>level</fieldName>
                    </logLevel>
                    <loggerName>
                        <fieldName>logger</fieldName>
                    </loggerName>
                    <pattern>
                        <pattern>
                            {"message":"%mask%msg"}
                        </pattern>
                    </pattern>
                    <mdc>
                        <includeMdcKeyName>traceId</includeMdcKeyName>
                        <includeMdcKeyName>correlationId</includeMdcKeyName>
                        <includeMdcKeyName>sessionId</includeMdcKeyName>
                        <includeMdcKeyName>userId</includeMdcKeyName>
                    </mdc>
                    <pattern>
                        <pattern>
                            {
                                "audit": true,
                                "service": "${APP_NAME}"
                            }
                        </pattern>
                    </pattern>
                </providers>
            </encoder>
        </appender>
        <logger name="com.suvidha.audit" level="INFO" additivity="false">
            <appender-ref ref="AUDIT_FILE"/>
            <appender-ref ref="ASYNC_JSON_CONSOLE"/>
        </logger>
    </springProfile>

</configuration>
